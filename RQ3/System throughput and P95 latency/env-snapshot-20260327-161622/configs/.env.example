# ===== 基础设施 =====
MYSQL_ROOT_PASSWORD=1234
MYSQL_DATABASE=oracle_adapter_10001
MYSQL_PORT=3306
MYSQL_MAX_CONNECTIONS=1200
MYSQL_MAX_USER_CONNECTIONS=1000

KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

GANACHE_PORT=7545
GANACHE_MNEMONIC=test test test test test test test test test test test junk
GANACHE_CHAIN_ID=1337

# 合约部署配置文件（相对 deploy/docker-lab）
CONTRACT_CONFIG_FILE=../../ContractAutoDeploy/config-eth.yml

# 合约地址（由脚本自动回填）
CHAIN_CONTRACT_ENTITY_MANAGER=
CHAIN_CONTRACT_REPUTATION_MANAGER=
CHAIN_CONTRACT_REQUEST_MANAGER=
CHAIN_CONTRACT_ORACLE_PROXY=
CHAIN_CONTRACT_CROSS_CHAIN_EVIDENCE=
CHAIN_CONTRACT_REQUEST_TEST=

# ===== 应用 =====
ADAPTER_PORT=15000
NODE_HTTP_BASE_PORT=16000
NODE_COMM_BASE_PORT=16100
NODE_REPLICA_COUNT=4
ORACLE_ID_PREFIX=102000003331954283
ORACLE_ID_BASE_SUFFIX=16400
PRIMARY_ADAPTER=true
BENCHMARK_SINGLE_ORACLE_MODE=false
BENCHMARK_SINGLE_ORACLE_ID=1020000033319542830000016401
SIGNATURE_VERIFY_ENABLED=false
ADAPTER_DB_POOL_MAX=16
ADAPTER_DB_POOL_MIN_IDLE=2
NODE_DB_POOL_MAX=2
NODE_DB_POOL_MIN_IDLE=1
NODE_JAVA_TOOL_OPTIONS=-Xms48m -Xmx160m -XX:+UseSerialGC -XX:MaxMetaspaceSize=96m
NODE_CPU_LIMIT=0.20
NODE_MEM_LIMIT=512m
CEA_DB_POOL_MAX=4
CEA_DB_POOL_MIN_IDLE=1

VRF_PORT=18000
CEA_PORT=34567

# 监控镜像（如海外仓库受限可改为可访问镜像）
CADVISOR_IMAGE=registry.cn-hangzhou.aliyuncs.com/google_containers/cadvisor:v0.47.2


# ===== 压测 =====
K6_VUS=50
K6_DURATION=60s
K6_TARGET_RPS=100
